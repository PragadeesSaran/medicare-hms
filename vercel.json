{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/api-server run build && pnpm --filter medicare-hms run build",
  "outputDirectory": "artifacts/medicare-hms/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.mjs" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  }
}

